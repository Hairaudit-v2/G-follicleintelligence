{
  "name": "follicleintelligence",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "check:env": "node scripts/run-with-system-ca.mjs tsx scripts/check-fi-env.ts",
    "check:migrations": "tsx scripts/check-migration-versions.ts",
    "check:env:production-rules": "tsx --test src/lib/env/fiEnv.server.test.ts",
    "smoke:prod": "tsx scripts/fi-production-smoke-test.ts",
    "smoke:reception-os": "tsx scripts/reception-os-smoke-test.ts",
    "smoke:financial-os": "tsx scripts/financial-os-smoke-test.ts",
    "validate:reception-os": "node -r ./scripts/patch-server-only-for-scripts.cjs ./node_modules/tsx/dist/cli.mjs scripts/reception-os-pilot-validation.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:security": "playwright test e2e/security",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:authenticated": "playwright test --grep @authenticated",
    "test:e2e:mutation": "playwright test --grep @mutation",
    "test:e2e:cross-browser": "playwright test e2e/security e2e/journeys",
    "test:e2e:security:production": "node scripts/run-e2e-security-production.mjs",
    "test:e2e:smoke:production": "node scripts/run-e2e-smoke-production.mjs",
    "replay:intelligence-event-logs": "node -r ./scripts/patch-server-only-for-scripts.cjs ./node_modules/tsx/dist/cli.mjs scripts/replay-intelligence-event-logs.ts",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:upload-phase3f": "tsx --test tests/hairauditImageClassifyEndpoint.test.ts",
    "test:imaging-os-im1": "tsx --test tests/imagingOsPhaseIm1.test.ts",
    "test:imaging-os-im2": "tsx --test tests/imagingOsPhaseIm2.test.ts",
    "test:imaging-os-im3": "tsx --test tests/imagingOsPhaseIm3.test.ts",
    "test:imaging-os-im4": "tsx --test tests/imagingOsPhaseIm4.test.ts",
    "test:imaging-os-im5": "tsx --test tests/imagingOsPhaseIm5.test.ts",
    "test:imaging-os-im6": "tsx --test tests/imagingOsPhaseIm6.test.ts",
    "test:imaging-os-im7": "tsx --test tests/imagingOsPhaseIm7.test.ts",
    "test:imaging-os-im8": "tsx --test tests/imagingOsPhaseIm8.test.ts",
    "test:imaging-os-im9": "tsx --test tests/imagingOsPhaseIm9.test.ts",
    "test:imaging-os-im10": "tsx --test tests/imagingOsPhaseIm10.test.ts",
    "test:imaging-os-im11": "tsx --test tests/imagingOsPhaseIm11.test.ts",
    "test:imaging-os-im12": "tsx --test tests/imagingOsPhaseIm12.test.ts",
    "calendar:perf-smoke": "cross-env NODE_ENV=development node -r ./scripts/patch-server-only-for-scripts.cjs ./node_modules/tsx/dist/cli.mjs scripts/calendar-loader-perf-smoke.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:ci": "prettier --write \"app/**/*.{ts,tsx,js,jsx,mjs}\" \"src/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"middleware.ts\" \"instrumentation.ts\" \".github/workflows/*.{yml,yaml}\"",
    "format:check:ci": "prettier --check \"app/**/*.{ts,tsx,js,jsx,mjs}\" \"src/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"middleware.ts\" \"instrumentation.ts\" \".github/workflows/*.{yml,yaml}\"",
    "copy-check": "tsx scripts/copy-check.ts",
    "verify:fi-events": "tsx scripts/verify-fi-event-ingestion.ts",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:db:reset": "npx supabase db reset",
    "supabase:migration:up": "npx supabase migration up",
    "supabase:migration:new": "npx supabase migration new",
    "supabase:push:remote:dry-run": "node scripts/push-pending-supabase-migrations.mjs --dry-run",
    "supabase:push:remote": "node scripts/push-pending-supabase-migrations.mjs --yes",
    "supabase:watch:migrations": "node scripts/watch-supabase-migrations.mjs",
    "smoke:network-subjects": "npx supabase db reset --yes && node scripts/run-supabase-sql-docker.mjs supabase/smoke/fi_network_subjects_foundation_smoke.sql",
    "smoke:network-subjects:only": "node scripts/run-supabase-sql-docker.mjs supabase/smoke/fi_network_subjects_foundation_smoke.sql",
    "supabase:push:consultations": "node scripts/apply-fi-consultations-remote.mjs",
    "supabase:push:post-op-tracking": "node scripts/apply-fi-case-post-op-tracking-remote.mjs",
    "dev:provision:evolved": "tsx scripts/provision-evolved-tenant.ts",
    "seed:enterprise-demo": "node scripts/run-with-system-ca.mjs tsx scripts/seedEnterpriseDemoTenant.ts",
    "seed:ihrg-demo": "node scripts/run-with-system-ca.mjs tsx scripts/seed-ihrg-demo-data.ts --tenant ihrg-demo --profile alive",
    "validate:titan-global-command-centre": "node scripts/run-with-system-ca.mjs tsx scripts/validateEnterpriseDemoGlobalCommandCentre.ts",
    "seed": "tsx scripts/seed-evolved-perth-service-room-eligibility.ts",
    "timely:import-preview": "tsx scripts/timely-service-sales-to-fi-seed.ts",
    "timely:build-approved": "tsx scripts/timely-build-approved-seed.ts",
    "timely:7a2": "npm run timely:import-preview && npm run timely:build-approved",
    "timely:7a4": "tsx scripts/excel-catalogue-to-approved-seed.ts",
    "import:approved-services": "tsx scripts/import-approved-fi-services.ts",
    "import:iiohr-hr-staff": "tsx scripts/import-iiohr-hr-staff.ts",
    "import:evolved-payroll-staff": "tsx scripts/import-evolved-payroll-staff.ts",
    "hubspot:commit-latest-batch": "node -r ./scripts/patch-server-only-for-scripts.cjs ./node_modules/tsx/dist/cli.mjs scripts/hubspot-commit-latest-dry-run-batch.ts",
    "hubspot:import-next-500": "node -r ./scripts/patch-server-only-for-scripts.cjs ./node_modules/tsx/dist/cli.mjs scripts/hubspot-import-next-500.ts",
    "hubspot:import-last-500-dry-run": "node -r ./scripts/patch-server-only-for-scripts.cjs ./node_modules/tsx/dist/cli.mjs scripts/hubspot-import-next-500.ts --last --dry-run",
    "hubspot:import-last-500": "node -r ./scripts/patch-server-only-for-scripts.cjs ./node_modules/tsx/dist/cli.mjs scripts/hubspot-import-next-500.ts --last",
    "hubspot:rollback-plan": "tsx scripts/hubspot-import-batch-rollback-plan.ts",
    "hubspot:rollback-execute": "tsx scripts/hubspot-import-batch-rollback-execute.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@follicle/intelligence-core": "file:packages/intelligence-core",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.2",
    "lucide-react": "^0.575.0",
    "next": "14.2.35",
    "pdf-lib": "^1.17.1",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^17.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.21.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.35",
    "@playwright/test": "1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "linkinator": "^7.6.1",
    "pg": "^8.16.3",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
