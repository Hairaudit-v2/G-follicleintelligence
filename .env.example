# Copy to `.env.local` and fill in values. Never commit real secrets.

# --- Core (Supabase + Next) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: canonical public URL (password reset / origin fallback)
# NEXT_PUBLIC_SITE_URL=https://www.example.com
# Optional: absolute app URL for scripts (HubSpot import, dry-run callers)
# NEXT_PUBLIC_APP_URL=https://www.example.com

# --- FI Admin / operator ---
# FI Admin home (`/fi-admin`) — optional local-only tenant directory when you have no Supabase login yet.
# Must be the string `true`. Ignored when NODE_ENV=production. See docs/dev-local-fi-admin.md
# FI_ENABLE_DEV_ADMIN_ACCESS=true

# Optional: FI Admin API key for some mutations (see codebase). Prefer `x-fi-admin-key` or `Authorization: Bearer`.
# In production, `?adminKey=` is never accepted. Local-only query support: `FI_ALLOW_ADMIN_KEY_QUERY=true` (ignored when NODE_ENV=production).
# FI_ADMIN_API_KEY=
# FI_ALLOW_ADMIN_KEY_QUERY=true

# Optional: script-only alias for import-approved-fi-services (see scripts/import-approved-fi-services.ts)
# FI_IMPORT_ADMIN_KEY=

# --- Cron + HR automation ---
# POST/GET /api/cron/fi-reminder-jobs — min 16 chars when set
# FI_REMINDER_CRON_SECRET=
# HR Perth cron self-POST — min 16 chars when set (see docs/iiohr-hr-perth-staff-sync-cron.md)
# CRON_SECRET=
# EVOLVED_PERTH_TENANT_ID=
# FI_BASE_URL=https://your-deploy.example.com
# IIOHR_HR_SYNC_SECRET=
# IIOHR_HR_PERTH_STAFF_FEED_URL=
# IIOHR_HR_PERTH_STAFF_FEED_KEY=
# ALLOW_EMPTY_HR_SYNC=true

# --- Timely / Zapier ---
# POST /api/tenants/[tenantId]/integrations/timely/patient|appointment|discovery — min 16 chars when set; required in production when routes are used
# FI_TIMELY_WEBHOOK_SECRET=

# --- Reminders (Resend + Twilio) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=reminders@your-verified-domain.com
# RESEND_FROM_NAME=Evolved Hair Clinics
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+447700900000
# TWILIO_DEFAULT_COUNTRY_CODE=44
# FI_REMINDERS_LIVE_DELIVERY=false
# FI_REMINDER_TEST_EMAIL=
# FI_REMINDERS_TEST_SEND=

# --- OpenAI (DoctorOS / pathology) ---
# OPENAI_API_KEY=
# OPENAI_CLINICAL_NOTE_MODEL=gpt-4o-mini
# OPENAI_PATHOLOGY_INTERPRETATION_MODEL=gpt-4o-mini

# --- Storage ---
# FI_STORAGE_BUCKET_INTAKES=fi-intakes

# --- HR health / alerts ---
# STAFF_SYNC_STALE_WARNING_HOURS=48
# STAFF_SYNC_ALERT_EMAIL=

# --- Development / UAT toggles (avoid in production) ---
# FI_DEVELOPMENT_ADMIN_AUTH_USER_IDS=
# FI_ALLOW_CALENDAR_UAT_SEED=true

# --- Dangerous API bypasses (local / locked-down staging only; blocked by `pnpm run check:env` in production) ---
# Skips session checks for `checkFiTenantPortalApiAccess`. Ignored when NODE_ENV=production.
# FI_ALLOW_INSECURE_API=true

# Legacy `/api/fi/*` machine routes (events, submit, uploads, cases, partners, run-model).
# FI_LEGACY_FI_API_ENABLED=true
# FI_LEGACY_FI_API_SECRET=

# --- HubSpot / tenant bootstrap scripts ---
# FI_HUBSPOT_IMPORT_TENANT_ID=
# FI_EVOLVED_TENANT_SLUG=evolved
# FI_EVOLVED_TENANT_NAME=Evolved Perth
# FI_EVOLVED_DEFAULT_TIMEZONE=Australia/Perth

# DoctorOS 1D — patient portal: link auth.users.id on fi_patients.portal_auth_user_id for /patient/[tenantId]/medications

# Legacy (no longer read by app code): previously toggled ClinicOsShell vs legacy tenant nav + gated
# global search. FI OS now always uses FiOsAppShell; global search uses tenant portal API access only.
# NEXT_PUBLIC_FI_CLINIC_OS_SHELL=true
