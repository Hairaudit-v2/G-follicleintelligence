# Copy to `.env.local` and fill in values. Never commit real secrets.

# Supabase (required for most FI Admin / API routes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# FI Admin home (`/fi-admin`) — optional local-only tenant directory when you have no Supabase login yet.
# Must be the string `true`. Ignored when NODE_ENV=production. See docs/dev-local-fi-admin.md
# FI_ENABLE_DEV_ADMIN_ACCESS=true

# Optional: FI Admin API key for some mutations (see codebase)
# FI_ADMIN_API_KEY=
