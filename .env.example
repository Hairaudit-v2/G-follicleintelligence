# Follicle Intelligence — environment template
# Copy to `.env.local` for local development. Never commit real secrets.
#
# Validation: pnpm run check:env  |  Zod schemas: src/lib/env/
# Import rules: client → @/src/env/client  |  server → @/src/env/server
# Related: docs/runbooks/environment-architecture.md

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Canonical public site URL — password-reset links, auth redirects, and origin fallback when Host headers are missing.
NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# Alternate base URL for verify/replay scripts; FI_BASE_URL takes precedence when both are set.
BASE_URL=http://localhost:3000

# Site root for scripts, HR self-POST, smoke tests, and HubSpot import admin links (no trailing /fi-admin path).
FI_BASE_URL=https://your-app.example.com

# Set to true to enable @next/bundle-analyzer during next build (next.config.mjs).
ANALYZE=false

# -----------------------------------------------------------------------------
# SEO (optional — production Search Console / Bing / IndexNow)
# -----------------------------------------------------------------------------

# Google Search Console HTML tag verification content value (meta name=google-site-verification).
GOOGLE_SITE_VERIFICATION=

# CalendarOS GC-1/GC-2 — Google Calendar OAuth (native connector).
# Redirect URI must match GET /api/google-calendar/oauth/callback on your deployment origin.
# GOOGLE_* fallbacks are supported when GOOGLE_CALENDAR_* vars are unset.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
# Required when Google Calendar OAuth is configured — encrypts stored tokens and signs OAuth state (≥16 chars).
FI_EXTERNAL_CONNECTOR_MASTER_KEY=your_external_connector_master_key_min_16_chars
# Optional dedicated secret for OAuth state HMAC (falls back to FI_EXTERNAL_CONNECTOR_MASTER_KEY).
GOOGLE_CALENDAR_OAUTH_STATE_SECRET=

# Bing Webmaster Tools meta verification content (msvalidate.01).
BING_SITE_VERIFICATION=

# IndexNow API key (8–128 alphanumeric/hyphen). Hosted at https://your-domain/{INDEXNOW_KEY}.txt
# Weekly ping: GET /api/cron/seo-indexnow with CRON_SECRET (Vercel cron on Mondays 06:00 UTC).
INDEXNOW_KEY=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Supabase project API URL — embedded in the browser bundle via NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) JWT — safe in client bundles; data access is enforced by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — server-only; bypasses RLS. Required in production. Never use NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database password for remote SQL apply scripts only (apply-fi-*-remote.mjs). Not used by Next.js runtime.
SUPABASE_DB_PASSWORD=your_supabase_db_password

# Supabase Storage bucket name for case/intake uploads (default when unset: fi-intakes).
FI_STORAGE_BUCKET_INTAKES=fi-intakes

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Opt-in legacy Bearer auth for selected /api/fi/* routes (default off). When enabled in production, FI_LEGACY_FI_API_SECRET is required (≥16 chars).
FI_LEGACY_FI_API_ENABLED=false

# Bearer secret for legacy FI API routes when FI_LEGACY_FI_API_ENABLED is affirmative.
FI_LEGACY_FI_API_SECRET=your_legacy_fi_api_secret_min_16_chars

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

# Enable RevenueOS Stripe checkout (fiPaymentEnv.server.ts).
FI_PAYMENTS_ENABLED=false

# Procedure Day Board orchestrator route (/fi-admin/[tenantId]/procedure-day). Default off in production.
FI_PROCEDURE_DAY_ENABLED=false

# Staff UAT mode — shows in-app screen guides and "Was this clear?" feedback widgets in FI Admin.
FI_STAFF_UAT_MODE_ENABLED=false

# Loader perf spans — logs sub-loader timings to stdout (dev/smoke profiling).
FI_LOADER_PERF_SPANS=false

# FI OS performance diagnostics — span/query/payload logging for loader profiling.
FI_PERF_DIAGNOSTICS_ENABLED=false

# Payment provider identifier (default: manual). Set to stripe for Stripe Checkout.
FI_PAYMENT_PROVIDER=manual

# Stripe secret API key — server-only.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe webhook signing secret for POST /api/fi-payments/stripe/webhook.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Checkout redirect URL after successful payment.
FI_PAYMENT_SUCCESS_URL=https://your-app.example.com/payments/success

# Checkout redirect URL when the patient cancels payment.
FI_PAYMENT_CANCEL_URL=https://your-app.example.com/payments/cancel

# Default informational expiry window in days for payment links (1–365; default 14).
FI_PAYMENT_REQUEST_EXPIRY_DAYS=14

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------

# OpenAI API key — voice clinical notes, pathology AI, and HLI classifiers (server-only).
OPENAI_API_KEY=sk-your_openai_api_key

# Default model for voice clinical note generation (falls back to gpt-4o-mini when unset).
OPENAI_CLINICAL_NOTE_MODEL=gpt-4o-mini

# Model for pathology AI interpretation (falls back to OPENAI_CLINICAL_NOTE_MODEL then gpt-4o-mini).
OPENAI_PATHOLOGY_INTERPRETATION_MODEL=gpt-4o-mini

# Pathology inbox PDF extraction pipeline (Sprint G). Default off — manual inbox workflow unchanged.
PATHOLOGY_EXTRACTION_ENABLED=false

# When true with extraction enabled, matched documents auto-create draft results from extracted markers.
PATHOLOGY_AUTO_DRAFT_ENABLED=false

# OCR provider for pathology inbox extraction (Sprint G2). Default stub for local/test.
# Options: fi-pathology-stub-v1 | aws-textract-v1 | google-vision-v1 | openai-vision-v1
PATHOLOGY_EXTRACTION_PROVIDER=fi-pathology-stub-v1

# Minimum document/marker confidence (0-1) before routing extraction to manual review.
PATHOLOGY_EXTRACTION_MIN_OCR_CONFIDENCE=0.55

# Model for OpenAI-compatible pathology marker extraction (openai-vision-v1 provider).
OPENAI_PATHOLOGY_EXTRACTION_MODEL=gpt-4o-mini

# AWS Textract credentials (aws-textract-v1 provider shell).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-2

# Google Cloud Vision credentials (google-vision-v1 provider shell).
# GOOGLE_CLOUD_VISION_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# -----------------------------------------------------------------------------
# Email / Resend
# -----------------------------------------------------------------------------

# Resend API key for transactional email (reminders, pathology, pharmacy surfaces).
RESEND_API_KEY=re_your_resend_api_key

# Verified sender address in Resend (required for live email delivery).
RESEND_FROM_EMAIL=noreply@your-domain.example

# Optional display name for the Resend From header.
RESEND_FROM_NAME=Your Clinic Name

# Optional Reply-To address (single or comma-separated) forwarded to Resend.
RESEND_REPLY_TO=support@your-domain.example

# Twilio account SID for SMS reminder delivery (optional if email-only).
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid

# Twilio auth token — server-only.
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Outbound SMS sender number (TWILIO_FROM_NUMBER or TWILIO_PHONE_NUMBER is accepted).
TWILIO_FROM_NUMBER=+10000000000

# Alternate env key for outbound SMS sender (either TWILIO_FROM_NUMBER or TWILIO_PHONE_NUMBER).
TWILIO_PHONE_NUMBER=

# Default country code for E.164 phone normalisation (e.g. 61 for Australia).
TWILIO_DEFAULT_COUNTRY_CODE=61

# Staging kill-switch: set false/0/off to skip live Resend/Twilio sends (reminder jobs are cancelled with an explanatory log).
FI_REMINDERS_LIVE_DELIVERY=true

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------

# Shared Vercel cron Bearer secret (≥16 chars when set). Authorises scheduled GETs from vercel.json.
CRON_SECRET=your_cron_secret_min_16_chars

# Bearer secret for POST/GET /api/cron/fi-reminder-jobs (also accepts CRON_SECRET).
FI_REMINDER_CRON_SECRET=your_reminder_cron_secret_min_16_chars

# Optional alias Bearer for GET /api/cron/iiohr-hr-perth-staff-sync (also accepts CRON_SECRET).
FI_HR_SYNC_CRON_SECRET=your_hr_sync_cron_secret_min_16_chars

# Bearer secret for GET /api/cron/fi-photo-protocol-alerts (also accepts CRON_SECRET).
FI_PHOTO_PROTOCOL_ALERTS_CRON_SECRET=your_photo_protocol_cron_secret_min_16_chars

# Bearer secret for POST/GET /api/cron/fi-imaging-ai-analysis (also accepts CRON_SECRET).
FI_IMAGING_AI_ANALYSIS_CRON_SECRET=your_imaging_ai_analysis_cron_secret_min_16_chars

# ImagingOS Phase 6 — optional live staff outcome/density signals (default off; staff-facing only).
FI_IMAGING_ENABLE_LIVE_DENSITY_PROVIDER=false
FI_IMAGING_ENABLE_LIVE_OUTCOME_PROVIDER=false
FI_IMAGING_ENABLE_LIVE_NORWOOD_PROVIDER=false

# Bearer secret accepted by financial-os cron routes (validateCronAuth).
FINANCIAL_OS_CRON_SECRET=your_financial_os_cron_secret_min_16_chars

# Bearer secret accepted by payment reminder cron (validateCronAuth).
FI_PAYMENTS_CRON_SECRET=your_payments_cron_secret_min_16_chars

# -----------------------------------------------------------------------------
# Security Secrets
# -----------------------------------------------------------------------------

# Break-glass admin API key for server actions and x-fi-admin-key routes (≥20 chars recommended when set).
FI_ADMIN_API_KEY=your_fi_admin_api_key_min_20_chars

# Production: required when FI_ADMIN_API_KEY is set — comma-separated tenant UUIDs the key may access.
# Omit in local dev to allow cross-tenant script use; never leave unset on production deployments.
FI_ADMIN_API_KEY_TENANT_ALLOWLIST=

# Patient portal clinical photography (/patient/*/imaging). Production defaults to off unless affirmative
# (true/1/yes). Non-production defaults to on unless explicitly false/0/no.
FI_PORTAL_IMAGING_ENABLED=false

# Script-only alias for FI_ADMIN_API_KEY (import-approved-fi-services.ts).
FI_IMPORT_ADMIN_KEY=your_fi_import_admin_key

# Master key for AES-256-GCM encryption of per-tenant machine-ingest HMAC secrets (≥32 chars in production).
FI_MACHINE_INGEST_MASTER_KEY=your_machine_ingest_master_key_min_32_chars

# Bearer secret for Timely/Zapier webhooks (POST .../integrations/timely/*). Required in production when webhooks are used (≥16 chars).
FI_TIMELY_WEBHOOK_SECRET=your_timely_webhook_secret_min_16_chars

# -----------------------------------------------------------------------------
# Timely Direct API (read-only sync — server-only; never exposed to client code)
# -----------------------------------------------------------------------------
# Secret used to authenticate FI → Timely API calls. Sent as `Authorization: Bearer <key>`
# by src/lib/integrations/timely/timelyApiClient.server.ts. Never logged, never NEXT_PUBLIC_*.
# NOTE: confirm the exact auth scheme for your Timely account (Bearer token vs OAuth2 access
# token vs custom header) before relying on the direct-sync path — see the client's TODOs.
TIMELY_API_KEY=your_timely_api_key

# Base URL for the Timely REST API, no trailing slash (e.g. https://api.gettimely.com/v1).
# Required (no default) so the client never calls an unconfirmed host. Confirm against the
# Timely API docs for your account/region.
TIMELY_API_BASE_URL=https://api.gettimely.com/v1

# Bearer secret guarding the (future) Timely direct-sync cron route. Not yet wired to a route —
# reserved for the cron sync that will be built only after the read-only API probe succeeds (≥16 chars when set).
FI_TIMELY_SYNC_CRON_SECRET=your_timely_sync_cron_secret_min_16_chars

# -----------------------------------------------------------------------------
# HubSpot Timeline Sync (inbound webhooks → fi_patient_timeline; server-only)
# -----------------------------------------------------------------------------
# Bearer secret for HubSpot timeline-sync webhooks
# (POST .../integrations/hubspot/{contact,email-event,deal}). Required in production when those
# webhooks are used (≥16 chars). Never logged. Separate from the HubSpot CSV import keys.
FI_HUBSPOT_WEBHOOK_SECRET=your_hubspot_webhook_secret_min_16_chars

# Shared secret for IIOHR → FI staff-sync POST (x-iiohr-sync-secret header; ≥16 chars when set).
IIOHR_HR_SYNC_SECRET=your_iiohr_hr_sync_secret_min_16_chars

# Development-only: allow insecure API bypass for clinic-os global search (must be false in production).
FI_ALLOW_INSECURE_API=false

# Development-only: allow ?adminKey= query param for admin routes (must be false in production).
FI_ALLOW_ADMIN_KEY_QUERY=false

# Opt-in public POST /api/fi/copy-check in production (default off).
FI_ENABLE_PUBLIC_COPY_CHECK=false

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
# No third-party analytics environment variables are referenced in application code.
# AnalyticsOS composes dashboards from Supabase via the server admin client.
# Vercel Web Analytics is enabled via the @vercel/analytics package (no env var required).

# -----------------------------------------------------------------------------
# ImagingOS
# -----------------------------------------------------------------------------
# No ImagingOS-specific environment variables are referenced in application code.
# Imaging uses Supabase storage (FI_STORAGE_BUCKET_INTAKES) and server-side loaders.

# -----------------------------------------------------------------------------
# HairAudit Integration
# -----------------------------------------------------------------------------

# Bearer token for HairAudit image classifier API auth (never substitute SUPABASE_SERVICE_ROLE_KEY).
HAIRAUDIT_IMAGE_CLASSIFIER_TOKEN=your_hairaudit_classifier_token_min_16_chars

# Classifier mode: stub for rollback/testing; omit or use live path for production OpenAI classification.
HAIRAUDIT_IMAGE_CLASSIFIER_MODE=

# Unified internal imaging classifier (FIN-IMAGING-2) — POST /api/internal/imaging/classify
# Primary bearer token; falls back to HAIRAUDIT_IMAGE_CLASSIFIER_TOKEN when unset.
FI_INTERNAL_IMAGING_CLASSIFIER_TOKEN=your_fi_internal_imaging_classifier_token_min_16_chars
# Optional HMAC secret when FI_INTERNAL_IMAGING_REQUIRE_HMAC=true
FI_INTERNAL_IMAGING_HMAC_SECRET=your_fi_internal_imaging_hmac_secret_min_16_chars
FI_INTERNAL_IMAGING_REQUIRE_HMAC=false
FI_INTERNAL_IMAGING_ALLOWED_SOURCES=fi_os,hairaudit,hli,iiohr

# -----------------------------------------------------------------------------
# HLI Integration
# -----------------------------------------------------------------------------

# OpenAI model overrides for Hair Longevity Intelligence (each falls back to OPENAI_CLINICAL_NOTE_MODEL).
OPENAI_HAIR_IMAGE_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_HAIR_LOSS_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_CONSULTATION_CHECKLIST_MODEL=gpt-4o-mini
OPENAI_DONOR_ASSESSOR_MODEL=gpt-4o-mini
OPENAI_RECIPIENT_ASSESSOR_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# IIOHR Integration
# -----------------------------------------------------------------------------

# HTTPS URL for Evolved Perth HR staff JSON feed (cron and manual sync).
# Use www — https://iiohr.com 307-redirects and fetch drops Authorization Bearer on cross-host redirect.
IIOHR_HR_PERTH_STAFF_FEED_URL=https://www.iiohr.com/api/hr/evolved-perth/staff-feed

# Optional Bearer key for GET on the staff feed URL.
IIOHR_HR_PERTH_STAFF_FEED_KEY=your_iiohr_staff_feed_key

# Target tenant UUID for Perth HR automation (runScheduledIiohrHrStaffSync).
EVOLVED_PERTH_TENANT_ID=00000000-0000-4000-8000-000000000000

# Allow HR cron to no-op on an empty feed without error (staging safety).
ALLOW_EMPTY_HR_SYNC=false

# PROJECT NEXUS — IIOHR → FI OS provisioning (Phase 9A; default off).
FI_OS_NEXUS_ENABLED=false
FI_OS_NEXUS_SECRET=your_fi_os_nexus_hmac_secret_min_16_chars
FI_OS_NEXUS_CREATE_AUTH_USER=false

# Hours before staff-sync health reports stale (default 48).
STAFF_SYNC_STALE_WARNING_HOURS=48

# Placeholder for future staff-sync alert email (logged intent only; delivery not wired).
STAFF_SYNC_ALERT_EMAIL=ops@your-domain.example

# -----------------------------------------------------------------------------
# FI OS Platform
# -----------------------------------------------------------------------------

# Tenant UUID for replay and verify scripts (scripts/replay-test.ts, verify-fi-event-ingestion.ts).
FI_TENANT_ID=00000000-0000-4000-8000-000000000000

# Case UUID for replay-job-lock-test.ts.
FI_CASE_ID=00000000-0000-4000-8000-000000000000

# Evolved tenant bootstrap defaults (provision-evolved-tenant.ts, HubSpot scripts).
FI_EVOLVED_TENANT_SLUG=evolved
FI_EVOLVED_TENANT_NAME=Evolved Perth
FI_EVOLVED_DEFAULT_TIMEZONE=Australia/Perth

# HubSpot CRM import scripts — target tenant UUID and safety confirmation gates.
FI_HUBSPOT_IMPORT_TENANT_ID=00000000-0000-4000-8000-000000000000
FI_HUBSPOT_IMPORT_CONFIRM=
FI_HUBSPOT_ROLLBACK_CONFIRM=

# Persist intelligence event logs when FI_INTELLIGENCE_EVENT_LOG_PERSIST_ENABLED=1 (non-production rules apply).
FI_INTELLIGENCE_EVENT_LOG_PERSIST_ENABLED=0

# Governed intelligence replay and dispatch flags (staging and admin tooling).
FI_INTELLIGENCE_GOVERNED_REPLAY_ENABLED=0
FI_INTELLIGENCE_GOVERNED_DISPATCH_ENABLED=0

# Internal intelligence bus shadow queue (non-production only when enabled).
FI_INTELLIGENCE_INTERNAL_BUS_QUEUE_ENABLED=0
FI_INTELLIGENCE_INTERNAL_BUS_SHADOW_ENABLED=0
FI_INTELLIGENCE_INTERNAL_BUS_OBSERVABILITY_ENABLED=0

# Staging intelligence activation (non-production; requires governed replay).
FI_INTELLIGENCE_STAGING_ACTIVATION_ENABLED=0
FI_INTELLIGENCE_STAGING_ALLOWED_EVENT=hairaudit.audit.completed

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------

# Lists all tenants without session when NODE_ENV !== production (never enable on Vercel production).
FI_ENABLE_DEV_ADMIN_ACCESS=false

# Comma-separated Supabase auth user UUIDs with broad ClinicOS dev access (avoid in shared staging).
FI_DEVELOPMENT_ADMIN_AUTH_USER_IDS=

# Enable calendar UAT seed outside NODE_ENV=development.
FI_ALLOW_CALENDAR_UAT_SEED=false

# Redirect test reminder emails here (never the patient); requires FI_REMINDERS_TEST_SEND=true.
FI_REMINDER_TEST_EMAIL=you+test@your-domain.example

# Allow explicit test reminder sends from calendar UAT UI.
FI_REMINDERS_TEST_SEND=false

# Opt-in FI_INTELLIGENCE_POLICY_DEV=1 for policy adapter tests.
FI_INTELLIGENCE_POLICY_DEV=0

# Playwright e2e base URL and optional tenant UUID (e2e/fixtures/baseUrl.ts).
FI_E2E_BASE_URL=http://localhost:3000
FI_E2E_TENANT_ID=00000000-0000-4000-8000-000000000000

# Placeholder credentials for future authenticated e2e fixture (e2e/fixtures/auth.ts; not wired yet).
FI_E2E_DEMO_ADMIN_EMAIL=demo-admin@your-domain.example
FI_E2E_DEMO_ADMIN_PASSWORD=your_throwaway_e2e_password
# Visual summary E2E (npm run seed:visual-summary-e2e)
FI_E2E_ALLOW_MUTATIONS=0
FI_E2E_VISUAL_SUMMARY_CASE_ID=
FI_E2E_VISUAL_SUMMARY_PATIENT_ID=
FI_E2E_PATIENT_PORTAL_EMAIL=e2e-visual-summary-portal@fi-demo.example
FI_E2E_PATIENT_PORTAL_PASSWORD=your_throwaway_portal_password
# Signed share links for approved visual summary PDFs (optional; falls back to CRON_SECRET)
PATIENT_VISUAL_SUMMARY_SHARE_SECRET=

# Production smoke test script targets (scripts/fi-production-smoke-test.ts).
FI_SMOKE_TENANT_ID=00000000-0000-4000-8000-000000000000
FI_SMOKE_OTHER_TENANT_ID=
# C4 consent gate smoke — patient without a consent document (scripts/c4-deploy-and-smoke.ts).
FI_SMOKE_PATIENT_ID=
# Force C4 HTTP 403 probe in smoke:c4 (server must have gate enabled).
FI_SMOKE_C4_GATE=0
# Trial consent gate — blocks imaging capture + consultation complete until consent uploaded.
# Alternative to tenant config_json.feature_flags.trial_require_consent_before_capture.
FI_TRIAL_REQUIRE_CONSENT_BEFORE_CAPTURE=false

# Calendar loader perf smoke script tenant and anchor date (scripts/calendar-loader-perf-smoke.ts).
CALENDAR_PERF_TENANT_ID=
CALENDAR_PERF_ANCHOR=2026-06-15

# Verbose logging for hubspot-post-import-audit.ts.
DEBUG_HUBSPOT_AUDIT=0

# Client-side verbose calendar hydrate logs in development (NEXT_PUBLIC_FI_CALENDAR_PERF=1).
NEXT_PUBLIC_FI_CALENDAR_PERF=0

# Skip Zod env validation during Docker image builds or CI when secrets are unavailable.
SKIP_ENV_VALIDATION=0
# Workforce sync consumer
IIOHR_HR_PERTH_STAFF_FEED_KEY=
# Unused by FI loaders — set IIOHR_HR_PERTH_STAFF_FEED_URL only (see comment above).
# IIOHR_HR_STAFF_FEED_URL=
CRON_SECRET=